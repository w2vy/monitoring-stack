# Copy to .env and fill in real values. .env is gitignored.
# Rotate any value here in the corresponding service UI / config:
#   INFLUX_PASSWORD  -> InfluxDB UI: Users -> admin -> change password
#   INFLUX_TOKEN     -> InfluxDB UI: Load Data -> API Tokens -> generate admin token
#   GRAFANA_PASSWORD -> Grafana UI: admin user -> change password
#   NUT_PASSWORD     -> upsd.users on each NUT master (action grants needed)

INFLUX_PASSWORD=changeme
INFLUX_TOKEN=changeme
GRAFANA_PASSWORD=changeme
NUT_PASSWORD=changeme
