# Telegraf host base config — Phase 1 IPMI monitoring
# Substitute __HOST__ and __TOKEN__ before deploy.

[agent]
  interval = "60s"
  round_interval = true
  metric_batch_size = 1000
  metric_buffer_limit = 30000
  collection_jitter = "0s"
  flush_interval = "10s"
  flush_jitter = "0s"
  precision = ""
  hostname = ""
  omit_hostname = false

[global_tags]
  host = "__HOST__"

[[outputs.influxdb_v2]]
  urls = ["http://192.168.102.200:8086"]
  token = "__TOKEN__"
  organization = "moltentech"
  bucket = "monitoring"
