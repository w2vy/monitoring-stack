{
  "uid": "disk-health",
  "title": "Disk Health",
  "tags": ["monitoring-stack", "smart", "disk"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-monitoring" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"monitoring\", tag: \"host\", predicate: (r) => r._measurement == \"smart_device\", start: -30d)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "sort": 1
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "**SMART telegraf input** rolled-out 2026-05-13 on **pve20 / pve40 / pve55** only — other Proxmox + GPU rigs have no data here (prereq **P-1** expands coverage). Default range = 30d but back-history caps at ~10d until rollout completes. Error panels show **current max per drive**; thresholds color 0 green, >0 red. UDMA-CRC spikes typically mean a **SATA cable / backplane** issue (see pve45 incident)."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Drives reporting (per host)",
      "gridPos": { "x": 0, "y": 3, "w": 6, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-monitoring" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"monitoring\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"smart_device\" and r._field == \"health_ok\")\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> last()\n  |> group(columns: [\"host\"])\n  |> count()"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ] },
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Health snapshot (latest per drive)",
      "gridPos": { "x": 6, "y": 3, "w": 18, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-monitoring" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"monitoring\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"smart_device\")\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> last()\n  |> keep(columns: [\"_field\", \"_value\", \"host\", \"device\", \"model\", \"serial_no\"])\n  |> toFloat()\n  |> group()\n  |> pivot(rowKey: [\"host\", \"device\", \"model\", \"serial_no\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> sort(columns: [\"host\", \"device\", \"serial_no\"])",
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": {
          "renameByName": {
            "host": "Host",
            "device": "Device",
            "model": "Model",
            "serial_no": "Serial",
            "health_ok": "Health",
            "temp_c": "Temp °C",
            "power_on_hours": "POH",
            "reallocated_sectors_count": "Reallocs",
            "udma_crc_errors": "UDMA CRC",
            "uncorrectable_errors": "Uncorr",
            "percent_lifetime_remain": "Life %"
          }
        } }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Health" },
            "properties": [
              { "id": "mappings", "value": [
                { "type": "value", "options": { "1": { "text": "OK", "color": "green", "index": 0 } } },
                { "type": "value", "options": { "0": { "text": "FAIL", "color": "red", "index": 1 } } }
              ] },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Reallocs" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 1 }
              ] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "UDMA CRC" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 1 }
              ] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Uncorr" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 1 }
              ] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Life %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 20 },
                { "color": "green", "value": 50 }
              ] } },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "basic" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Temp °C" },
            "properties": [
              { "id": "unit", "value": "celsius" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 45 },
                { "color": "red", "value": 55 }
              ] } }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Drive temperature (°C)",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-monitoring" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"monitoring\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_device\" and r._field == \"temp_c\")\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> group(columns: [\"host\", \"device\", \"model\", \"serial_no\"])\n  |> keep(columns: [\"_time\", \"_value\", \"host\", \"device\", \"model\", \"serial_no\"])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1, "fillOpacity": 0, "showPoints": "never", "spanNulls": false },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 45 },
            { "color": "red", "value": 55 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Reallocated sectors (current per drive, hides 0)",
      "gridPos": { "x": 0, "y": 15, "w": 8, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-monitoring" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"monitoring\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"smart_device\" and r._field == \"reallocated_sectors_count\")\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> last()\n  |> filter(fn: (r) => r._value > 0)\n  |> keep(columns: [\"_value\", \"host\", \"device\", \"model\", \"serial_no\"])"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "text": { "valueSize": 32 }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] },
          "unit": "none",
          "noValue": "all clean",
          "displayName": "${__field.labels.host} ${__field.labels.serial_no}"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "UDMA CRC errors (current per drive, hides 0)",
      "gridPos": { "x": 8, "y": 15, "w": 8, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-monitoring" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"monitoring\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"smart_device\" and r._field == \"udma_crc_errors\")\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> last()\n  |> filter(fn: (r) => r._value > 0)\n  |> keep(columns: [\"_value\", \"host\", \"device\", \"model\", \"serial_no\"])"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "text": { "valueSize": 32 }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] },
          "unit": "none",
          "noValue": "all clean",
          "displayName": "${__field.labels.host} ${__field.labels.serial_no}"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Uncorrectable errors (current per drive, hides 0)",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-monitoring" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"monitoring\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"smart_device\" and r._field == \"uncorrectable_errors\")\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> last()\n  |> filter(fn: (r) => r._value > 0)\n  |> keep(columns: [\"_value\", \"host\", \"device\", \"model\", \"serial_no\"])"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "text": { "valueSize": 32 }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] },
          "unit": "none",
          "noValue": "all clean",
          "displayName": "${__field.labels.host} ${__field.labels.serial_no}"
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "SSD life remaining (%)",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-monitoring" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"monitoring\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_device\" and r._field == \"percent_lifetime_remain\")\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> group(columns: [\"host\", \"device\", \"model\", \"serial_no\"])\n  |> keep(columns: [\"_time\", \"_value\", \"host\", \"device\", \"model\", \"serial_no\"])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 20 },
            { "color": "green", "value": 50 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "min"] },
        "tooltip": { "mode": "multi", "sort": "asc" }
      }
    }
  ]
}
